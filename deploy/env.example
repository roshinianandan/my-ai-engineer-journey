# Copy this to .env and fill in your values
# cp deploy/env.example .env

# ── API Security ──────────────────────────────────────────────────────────────
API_KEY=your-secret-api-key-here

# ── Model Configuration ───────────────────────────────────────────────────────
MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434

# ── Application Settings ──────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=info

# ── Frontend Settings ─────────────────────────────────────────────────────────
API_URL=http://localhost:8000